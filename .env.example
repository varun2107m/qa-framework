# ─── Copy this to .env and fill in values ────────────────────────────────────
# .env is gitignored — never commit real credentials.

# ── Browser & runner ──────────────────────────────────────────────────────────
ENV=qa                     # qa | staging
BROWSER=chromium           # chromium | firefox | webkit
HEADLESS=false             # true in CI, false locally
SLOW_MO=0                  # ms delay between actions (useful for debugging)
WORKERS=1                  # parallel workers (pytest-xdist)
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# ── Test credentials ──────────────────────────────────────────────────────────
STANDARD_USERNAME=standard_user
STANDARD_PASSWORD=secret_sauce
ADMIN_USERNAME=admin_user
ADMIN_PASSWORD=
LOCKED_USERNAME=locked_out_user
LOCKED_PASSWORD=secret_sauce
PROBLEM_USERNAME=problem_user
PROBLEM_PASSWORD=secret_sauce

# ── AI Orchestrator — OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...      # platform.openai.com/api-keys
LLM_MODEL=gpt-4            # gpt-4 | gpt-3.5-turbo
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0        # seconds, doubles each retry

# ── AI Orchestrator — GitHub ──────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...       # github.com/settings/tokens  (repo read scope)
GITHUB_REPO=owner/repo     # e.g. acme-corp/my-app

# ── AI Orchestrator — Jira ────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=...         # id.atlassian.com/manage-profile/security/api-tokens